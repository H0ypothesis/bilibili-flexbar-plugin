{
    "name": "BilibiliPlugin",
    "uuid": "com.h0ypothesis.bilibili",
    "version": "1.2.0",
    "author": "H0ypothesis",
    "entry": "backend/plugin.cjs",
    "description": "哔哩哔哩控制面板 - 通过 Electron 调试协议驱动 Mac 客户端播放器（进度拖拽/播放暂停/下一集/音量/弹幕/点赞投币收藏）",
    "repo": "https://github.com/H0ypothesis/bilibili-flexbar-plugin.git",
    "sdk": {
        "version": "1.0.0"
    },
    "software": {
        "minimumVersion": "1.0.0"
    },
    "os": [
        {
            "platform": "mac",
            "minimumVersion": "11.0"
        }
    ],
    "device": [
        {
            "name": "flexbar",
            "version": "1.0.0"
        }
    ],
    "configPage": "configPage",
    "keyLibrary": {
        "title": "$PluginName",
        "style": {
            "icon": "data:image/png;base64,"
        },
        "children": [
            {
                "title": "$NowPlaying.Title",
                "tip": "$NowPlaying.Tip",
                "cid": "com.h0ypothesis.bilibili.nowplaying",
                "config": {
                    "keyType": "default",
                    "clickable": false,
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-television-play",
                    "width": 600,
                    "flags": ["disable-bg", "disable-fg", "disable-icon-sel", "disable-layout-sel"]
                },
                "data": {
                    "showTitle": true,
                    "showUp": true,
                    "showCover": true,
                    "showProgress": true
                }
            },
            {
                "title": "$Progress.Title",
                "tip": "$Progress.Tip",
                "cid": "com.h0ypothesis.bilibili.progress",
                "config": {
                    "keyType": "slider",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-blank",
                    "width": 940,
                    "slider": {
                        "color": "#FB7299",
                        "width": 920,
                        "format": "%0.0f%%",
                        "min": 0,
                        "max": 100,
                        "decimals": 0
                    }
                },
                "data": {}
            },
            {
                "title": "$PlayPause.Title",
                "tip": "$PlayPause.Tip",
                "cid": "com.h0ypothesis.bilibili.playpause",
                "config": {
                    "keyType": "multiState",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-play",
                    "width": 120,
                    "multiStyle": [
                        {
                            "icon": "mdi mdi-play",
                            "fgColor": "#FFFFFF"
                        },
                        {
                            "icon": "mdi mdi-pause",
                            "fgColor": "#FB7299"
                        }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Next.Title",
                "tip": "$Next.Tip",
                "cid": "com.h0ypothesis.bilibili.next",
                "config": {
                    "keyType": "default",
                    "clickable": true,
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-skip-next",
                    "width": 120
                },
                "data": {}
            },
            {
                "title": "$Back15.Title",
                "tip": "$Back15.Tip",
                "cid": "com.h0ypothesis.bilibili.back",
                "config": {
                    "keyType": "default",
                    "clickable": true,
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-rewind-15",
                    "width": 120
                },
                "data": {}
            },
            {
                "title": "$Forward15.Title",
                "tip": "$Forward15.Tip",
                "cid": "com.h0ypothesis.bilibili.forward",
                "config": {
                    "keyType": "default",
                    "clickable": true,
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-fast-forward-15",
                    "width": 120
                },
                "data": {}
            },
            {
                "title": "$SeekWheel.Title",
                "tip": "$SeekWheel.Tip",
                "cid": "com.h0ypothesis.bilibili.seekwheel",
                "config": {
                    "keyType": "wheel",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-rotate-right",
                    "width": 120,
                    "wheel": {
                        "step": 5
                    }
                },
                "data": {}
            },
            {
                "title": "$Volume.Title",
                "tip": "$Volume.Tip",
                "cid": "com.h0ypothesis.bilibili.volumewheel",
                "config": {
                    "keyType": "wheel",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-volume-high",
                    "width": 120,
                    "wheel": {
                        "step": 5
                    }
                },
                "data": {}
            },
            {
                "title": "$Danmaku.Title",
                "tip": "$Danmaku.Tip",
                "cid": "com.h0ypothesis.bilibili.danmaku",
                "config": {
                    "keyType": "multiState",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-comment-text-outline",
                    "width": 120,
                    "multiStyle": [
                        { "icon": "mdi mdi-comment-off-outline", "fgColor": "#9499A0" },
                        { "icon": "mdi mdi-comment-text-multiple", "fgColor": "#FB7299" }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Like.Title",
                "tip": "$Like.Tip",
                "cid": "com.h0ypothesis.bilibili.like",
                "config": {
                    "keyType": "multiState",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-thumb-up-outline",
                    "width": 120,
                    "multiStyle": [
                        { "icon": "mdi mdi-thumb-up-outline", "fgColor": "#FFFFFF" },
                        { "icon": "mdi mdi-thumb-up", "fgColor": "#FB7299" }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Coin.Title",
                "tip": "$Coin.Tip",
                "cid": "com.h0ypothesis.bilibili.coin",
                "config": {
                    "keyType": "multiState",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-circle-multiple-outline",
                    "width": 120,
                    "multiStyle": [
                        { "icon": "mdi mdi-circle-multiple-outline", "fgColor": "#FFFFFF" },
                        { "icon": "mdi mdi-circle-multiple", "fgColor": "#FB7299" }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Favorite.Title",
                "tip": "$Favorite.Tip",
                "cid": "com.h0ypothesis.bilibili.favorite",
                "config": {
                    "keyType": "multiState",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-star-outline",
                    "width": 120,
                    "multiStyle": [
                        { "icon": "mdi mdi-star-outline", "fgColor": "#FFFFFF" },
                        { "icon": "mdi mdi-star", "fgColor": "#FB7299" }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Fullscreen.Title",
                "tip": "$Fullscreen.Tip",
                "cid": "com.h0ypothesis.bilibili.fullscreen",
                "config": {
                    "keyType": "multiState",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-fullscreen",
                    "width": 120,
                    "multiStyle": [
                        { "icon": "mdi mdi-fullscreen", "fgColor": "#FFFFFF" },
                        { "icon": "mdi mdi-fullscreen-exit", "fgColor": "#FB7299" }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Subtitle.Title",
                "tip": "$Subtitle.Tip",
                "cid": "com.h0ypothesis.bilibili.subtitle",
                "config": {
                    "keyType": "default",
                    "clickable": false,
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-subtitles-outline",
                    "width": 600,
                    "flags": ["disable-bg", "disable-fg", "disable-icon-sel", "disable-layout-sel"]
                },
                "data": {}
            },
            {
                "title": "$AutoSubtitle.Title",
                "tip": "$AutoSubtitle.Tip",
                "cid": "com.h0ypothesis.bilibili.autosubtitle",
                "config": {
                    "keyType": "multiState",
                    "platform": ["mac"]
                },
                "style": {
                    "icon": "mdi mdi-closed-caption-outline",
                    "width": 120,
                    "multiStyle": [
                        { "icon": "mdi mdi-closed-caption-outline", "fgColor": "#9499A0" },
                        { "icon": "mdi mdi-closed-caption", "fgColor": "#FB7299" }
                    ]
                },
                "data": {}
            }
        ]
    },
    "local": {
        "en": {
            "PluginName": "Bilibili",
            "Config": {
                "Title": "Bilibili Setup",
                "Step1": {
                    "Title": "Start the bridge service",
                    "Description": "The plugin talks to a small local bridge that drives the Bilibili Mac app. Start it once in a terminal (keep it running), or install it as a login agent.",
                    "Instructions": "In the project folder run:\n\n  npm install        (first time only)\n  npm run macos:bridge\n\nOr install it to auto-start on login:\n\n  bash macos-bridge/install-launchagent.sh",
                    "Button": "Copy command"
                },
                "Step2": {
                    "Title": "Run Bilibili in debug mode",
                    "Description": "The Bilibili app must run with a remote-debugging port so the plugin can control its player. The plugin launches it that way automatically; if it's already running without the port, click below to restart it in debug mode.",
                    "Button": "Restart Bilibili (debug mode)",
                    "Idle": "Not restarted yet",
                    "Working": "Restarting…",
                    "Done": "Bilibili restarted in debug mode",
                    "Error": "Failed to restart Bilibili"
                },
                "Step3": {
                    "Title": "Test connection",
                    "Description": "Play any video in the Bilibili app, then test the connection.",
                    "Button": "Test connection",
                    "Idle": "Click to test",
                    "Testing": "Testing…",
                    "Connected": "Connected",
                    "NotConnected": "Not connected. Make sure Bilibili is running in debug mode (use the button above) and a video is playing."
                },
                "Next": "Next",
                "Back": "Back",
                "Finish": "Finish",
                "Complete": "Setup complete!"
            },
            "NowPlaying": {
                "Title": "Now Playing",
                "Tip": "Show current video, uploader, cover and progress",
                "UI": {
                    "ShowTitle": "Show Title",
                    "ShowUp": "Show Uploader",
                    "ShowCover": "Show Cover",
                    "ShowProgress": "Show Progress Bar"
                }
            },
            "Progress": { "Title": "Progress", "Tip": "Drag to seek the video" },
            "PlayPause": { "Title": "Play/Pause", "Tip": "Toggle playback" },
            "Volume": { "Title": "Volume", "Tip": "Rotate to change the video's volume (in-app, not system)" },
            "Danmaku": { "Title": "Danmaku", "Tip": "Show / hide danmaku (on-screen comments)" },
            "Next": { "Title": "Next", "Tip": "Next part / episode" },
            "Back15": { "Title": "Back 15s", "Tip": "Rewind 15 seconds" },
            "Forward15": { "Title": "Forward 15s", "Tip": "Forward 15 seconds" },
            "SeekWheel": { "Title": "Seek Wheel", "Tip": "Rotate to fine-tune the position" },
            "Like": { "Title": "Like", "Tip": "Like the video (tap again to undo)" },
            "Coin": { "Title": "Coin", "Tip": "Give a coin — may open a confirm dialog unless you turned that off in Bilibili" },
            "Favorite": { "Title": "Favorite", "Tip": "Add to favorites — opens the folder picker" },
            "Fullscreen": { "Title": "Fullscreen", "Tip": "Toggle fullscreen (highlighted when on)" },
            "Subtitle": { "Title": "Subtitle", "Tip": "Show the current subtitle line (when the video has subtitles turned on)" },
            "AutoSubtitle": { "Title": "Auto Subtitle", "Tip": "When on, subtitles are auto-enabled on each new video (original language). Persists across restarts." }
        },
        "zh-CN": {
            "PluginName": "哔哩哔哩",
            "Config": {
                "Title": "哔哩哔哩设置",
                "Step1": {
                    "Title": "启动桥接服务",
                    "Description": "插件通过一个本地小服务来驱动哔哩哔哩 Mac 客户端。请在终端启动它一次（保持运行），或装成开机自启。",
                    "Instructions": "在项目目录执行：\n\n  npm install        （首次）\n  npm run macos:bridge\n\n或安装为开机自启：\n\n  bash macos-bridge/install-launchagent.sh",
                    "Button": "复制命令"
                },
                "Step2": {
                    "Title": "以调试模式运行哔哩哔哩",
                    "Description": "哔哩哔哩需要带「远程调试端口」启动，插件才能控制它。插件会自动以调试端口拉起它；若它已在运行但没开端口，点下方一键重启。",
                    "Button": "一键重启哔哩哔哩（调试模式）",
                    "Idle": "尚未重启",
                    "Working": "正在重启…",
                    "Done": "已以调试模式重启哔哩哔哩",
                    "Error": "重启失败"
                },
                "Step3": {
                    "Title": "测试连接",
                    "Description": "在哔哩哔哩里播放任意视频，然后测试连接。",
                    "Button": "测试连接",
                    "Idle": "点击测试",
                    "Testing": "正在测试…",
                    "Connected": "连接成功",
                    "NotConnected": "未连接。请确认哔哩哔哩以调试模式运行（可用上面的按钮重启），并在播放视频。"
                },
                "Next": "下一步",
                "Back": "上一步",
                "Finish": "完成",
                "Complete": "设置完成！"
            },
            "NowPlaying": {
                "Title": "正在播放",
                "Tip": "显示当前视频、UP主、封面与进度",
                "UI": {
                    "ShowTitle": "显示标题",
                    "ShowUp": "显示UP主",
                    "ShowCover": "显示封面",
                    "ShowProgress": "显示进度条"
                }
            },
            "Progress": { "Title": "进度条", "Tip": "拖动以跳转进度" },
            "PlayPause": { "Title": "播放/暂停", "Tip": "切换播放状态" },
            "Volume": { "Title": "音量", "Tip": "旋转调节视频音量（软件内，非系统音量）" },
            "Danmaku": { "Title": "弹幕", "Tip": "显示 / 隐藏弹幕" },
            "Next": { "Title": "下一集", "Tip": "下一P / 下一集" },
            "Back15": { "Title": "快退15秒", "Tip": "后退 15 秒" },
            "Forward15": { "Title": "快进15秒", "Tip": "前进 15 秒" },
            "SeekWheel": { "Title": "进度旋钮", "Tip": "旋转以微调进度" },
            "Like": { "Title": "点赞", "Tip": "给视频点赞（再按一次取消）" },
            "Coin": { "Title": "投币", "Tip": "投币 —— 若未在 B 站关闭确认，会弹出确认框" },
            "Favorite": { "Title": "收藏", "Tip": "收藏 —— 打开收藏夹选择" },
            "Fullscreen": { "Title": "全屏", "Tip": "打开 / 关闭全屏（全屏时高亮）" },
            "Subtitle": { "Title": "字幕", "Tip": "显示当前字幕（需视频已开启字幕）" },
            "AutoSubtitle": { "Title": "自动字幕", "Tip": "开启后，进入新视频自动打开字幕（原文单语）；重启也记得该设置" }
        },
        "ja": {
            "PluginName": "ビリビリ",
            "Config": {
                "Title": "ビリビリ設定",
                "Step1": {
                    "Title": "ブリッジサービスを起動",
                    "Description": "本プラグインはローカルの小さなブリッジ経由でビリビリ Mac アプリを操作します。ターミナルで一度起動（起動したまま）するか、ログイン時自動起動として導入してください。",
                    "Instructions": "プロジェクトフォルダで実行：\n\n  npm install        （初回のみ）\n  npm run macos:bridge\n\nまたは自動起動として導入：\n\n  bash macos-bridge/install-launchagent.sh",
                    "Button": "コマンドをコピー"
                },
                "Step2": {
                    "Title": "デバッグモードでビリビリを起動",
                    "Description": "ビリビリをリモートデバッグポート付きで起動する必要があります。プラグインが自動で起動しますが、ポートなしで起動済みの場合は下のボタンで再起動してください。",
                    "Button": "ビリビリを再起動（デバッグ）",
                    "Idle": "未再起動",
                    "Working": "再起動中…",
                    "Done": "デバッグモードで再起動しました",
                    "Error": "再起動に失敗しました"
                },
                "Step3": {
                    "Title": "接続テスト",
                    "Description": "ビリビリで任意の動画を再生してから接続をテストしてください。",
                    "Button": "接続をテスト",
                    "Idle": "クリックしてテスト",
                    "Testing": "テスト中…",
                    "Connected": "接続成功",
                    "NotConnected": "未接続。ビリビリがデバッグモードで起動しているか（上のボタンで再起動）、動画を再生しているか確認してください。"
                },
                "Next": "次へ",
                "Back": "戻る",
                "Finish": "完了",
                "Complete": "設定完了！"
            },
            "NowPlaying": {
                "Title": "再生中",
                "Tip": "現在の動画 / 投稿者 / サムネ / 進行を表示",
                "UI": {
                    "ShowTitle": "タイトルを表示",
                    "ShowUp": "投稿者を表示",
                    "ShowCover": "サムネを表示",
                    "ShowProgress": "進行バーを表示"
                }
            },
            "Progress": { "Title": "進行バー", "Tip": "ドラッグでシーク" },
            "PlayPause": { "Title": "再生/一時停止", "Tip": "再生を切り替え" },
            "Volume": { "Title": "音量", "Tip": "回して動画の音量を調整（システムではなくアプリ内）" },
            "Danmaku": { "Title": "弾幕", "Tip": "弾幕の表示 / 非表示" },
            "Next": { "Title": "次へ", "Tip": "次のパート / 話" },
            "Back15": { "Title": "15秒戻る", "Tip": "15秒巻き戻し" },
            "Forward15": { "Title": "15秒進む", "Tip": "15秒早送り" },
            "SeekWheel": { "Title": "シークホイール", "Tip": "回して微調整" },
            "Like": { "Title": "いいね", "Tip": "いいね（もう一度で取り消し）" },
            "Coin": { "Title": "コイン", "Tip": "コインを投げる —— Bilibili設定次第で確認ダイアログが出ます" },
            "Favorite": { "Title": "お気に入り", "Tip": "お気に入り —— フォルダ選択が開きます" },
            "Fullscreen": { "Title": "フルスクリーン", "Tip": "フルスクリーン切り替え（オン時ハイライト）" },
            "Subtitle": { "Title": "字幕", "Tip": "現在の字幕を表示（動画で字幕オン時）" },
            "AutoSubtitle": { "Title": "字幕自動", "Tip": "オンにすると新しい動画で字幕を自動表示（原語・単一）。再起動後も保持" }
        }
    }
}
